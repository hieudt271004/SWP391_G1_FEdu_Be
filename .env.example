# =========================================================================
# FEdu Project - Docker Environment Configuration Template (.env.example)
# =========================================================================
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit your actual '.env' file with real credentials to git!

# -------------------------------------------------------------------------
# 1. Database Configuration (PostgreSQL)
# -------------------------------------------------------------------------
# Database connection URL (Default points to Neon.tech cloud instance)
DB_URL=jdbc:postgresql://ep-square-rain-aonmzhf3-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&prepareThreshold=0

# Database credentials
DB_USERNAME=neondb_owner
DB_PASSWORD=your_database_password_here

# -------------------------------------------------------------------------
# 2. Email Service Configuration (Gmail SMTP)
# -------------------------------------------------------------------------
# App-specific password for Gmail (e.g. hieudtfptu@gmail.com)
# To generate one: Google Account Settings -> Security -> App Passwords
MAIL_PASSWORD=your_gmail_app_password_here

# -------------------------------------------------------------------------
# 3. Security & JWT Configuration (JSON Web Token)
# -------------------------------------------------------------------------
# Secret keys for signing JWT tokens.
# IMPORTANT: These keys MUST be Base64-encoded strings and represent at least 256 bits (32 bytes) of data.
# The default values provided below are pre-generated valid Base64 strings for testing.
# Replace them with custom secure base64 strings in production.

# Base64 of: this-is-a-very-secure-and-long-access-token-key-for-fedu
JWT_ACCESS_KEY=dGhpcy1pcy1hLXZlcnktc2VjdXJlLWFuZC1sb25nLWFjY2Vzcy10b2tlbi1rZXktZm9yLWZlZHU=

# Base64 of: this-is-a-very-secure-and-long-refresh-token-key-for-fedu
JWT_REFRESH_KEY=dGhpcy1pcy1hLXZlcnktc2VjdXJlLWFuZC1sb25nLXJlZnJlc2gtdG9rZW4ta2V5LWZvci1mZWR1

# Base64 of: this-is-a-very-secure-and-long-reset-token-key-for-fedu
JWT_RESET_KEY=dGhpcy1pcy1hLXZlcnktc2VjdXJlLWFuZC1sb25nLXJlc2V0LXRva2VuLWtleS1mb3ItZmVkdQ==

# -------------------------------------------------------------------------
# 4. CORS & Frontend Configuration
# -------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated URLs)
# Port 80 is used here as the frontend container exposes on port 80 in docker-compose.
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://localhost:80
